.icon-font {
  flex: 0 0 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.icon-font.plain {
  background: transparent !important;
}

.icon-font.plain .icon-glyph {
  width: 100%;
  height: 100%;
}

.icon-glyph {
  width: 66%;
  height: 66%;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

