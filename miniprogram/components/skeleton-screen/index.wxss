.skeleton {
  padding-top: 24rpx;
}

.sk-strip,
.sk-card,
.sk-line,
.sk-block,
.sk-head,
.sk-row {
  position: relative;
  overflow: hidden;
  background: #e9eef6;
}

.sk-strip::after,
.sk-card::after,
.sk-line::after,
.sk-block::after,
.sk-head::after,
.sk-row::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.52), rgba(255, 255, 255, 0));
  animation: sk-shimmer 1.25s infinite;
}

.sk-strip {
  height: 72rpx;
  border-radius: 18rpx;
  margin-bottom: 24rpx;
}

.sk-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf5;
}

.sk-hero {
  min-height: 320rpx;
}

.sk-line {
  height: 28rpx;
  border-radius: 14rpx;
  margin-top: 20rpx;
}

.sk-line.short {
  width: 140rpx;
  margin-top: 0;
}

.sk-line.medium {
  width: 240rpx;
}

.sk-line.full {
  width: 100%;
}

.sk-line.amount {
  width: 360rpx;
  height: 58rpx;
  border-radius: 18rpx;
}

.sk-grid {
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.sk-block {
  height: 104rpx;
  border-radius: 16rpx;
}

.sk-head {
  width: 220rpx;
  height: 34rpx;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
}

.sk-row {
  height: 76rpx;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.sk-card.compact {
  min-height: 180rpx;
}

@keyframes sk-shimmer {
  100% {
    transform: translateX(100%);
  }
}
