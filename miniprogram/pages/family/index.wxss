.family-page {
  padding-bottom: 44rpx;
}

.family-summary {
  margin-top: 24rpx;
}

.family-total {
  margin-top: 10rpx;
  color: #101827;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 850;
}

.family-summary-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.family-summary-grid view {
  min-height: 92rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.family-summary-grid text:first-child {
  color: #667085;
  font-size: 23rpx;
}

.family-summary-grid text:last-child {
  color: #101827;
  font-size: 30rpx;
  font-weight: 800;
}

.family-summary-row {
  min-height: 92rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid #edf1f7;
}

.family-summary-row:active {
  opacity: 0.72;
}

.summary-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-name {
  color: #101827;
  font-size: 28rpx;
  font-weight: 750;
}

.summary-number {
  max-width: 220rpx;
  color: #101827;
  font-size: 28rpx;
  font-weight: 800;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-chevron {
  flex: 0 0 auto;
  color: #9aa3b2;
  font-size: 38rpx;
  line-height: 1;
}

.invite-code-box {
  margin-top: 28rpx;
  min-height: 96rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1769ff;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
}

.invite-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.invite-action {
  height: 78rpx;
  font-size: 28rpx;
}

.invite-input-row {
  margin-top: 26rpx;
  min-height: 92rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
}

.invite-input {
  flex: 1;
  height: 76rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 650;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.bind-btn {
  margin-top: 22rpx;
}

.empty-line {
  padding: 42rpx 24rpx;
  text-align: center;
  color: #8b94a5;
}
