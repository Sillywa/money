.family-page {
  padding-bottom: 44rpx;
}

.family-summary {
  margin-top: 24rpx;
}

.family-total {
  margin-top: 10rpx;
  color: #101827;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 850;
}

.family-goal-inline {
  margin-top: 18rpx;
}

.family-goal-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  color: #667085;
  font-size: 24rpx;
  font-weight: 650;
}

.progress-track {
  margin-top: 14rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #edf1f7;
  overflow: hidden;
}

.progress-fill {
  height: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1769ff, #13a37b);
  transition: width 120ms ease-out;
}

.family-goal-remain {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
}

.family-summary-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.family-summary-grid view {
  min-height: 92rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.family-summary-grid text:first-child {
  color: #667085;
  font-size: 23rpx;
}

.family-summary-grid text:last-child {
  color: #101827;
  font-size: 30rpx;
  font-weight: 800;
}

.family-member-list {
  margin-top: 18rpx;
}

.family-summary-row {
  min-height: 104rpx;
  padding: 18rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid #edf1f7;
}

.family-summary-row:active {
  opacity: 0.72;
}

.summary-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-name {
  color: #101827;
  font-size: 28rpx;
  font-weight: 750;
}

.summary-side {
  max-width: 230rpx;
  text-align: right;
}

.summary-number {
  color: #101827;
  font-size: 28rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-contribution {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 650;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-chevron {
  flex: 0 0 auto;
  color: #9aa3b2;
  font-size: 38rpx;
  line-height: 1;
}

.invite-code-box {
  margin-top: 28rpx;
  min-height: 96rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1769ff;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
}

.invite-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.invite-action {
  height: 78rpx;
  font-size: 28rpx;
}

.invite-input-row {
  margin-top: 26rpx;
  min-height: 92rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
}

.invite-input {
  flex: 1;
  height: 76rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 650;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.bind-btn {
  margin-top: 22rpx;
}

.empty-line {
  padding: 42rpx 24rpx;
  text-align: center;
  color: #8b94a5;
}
