.family-page {
  padding-bottom: 44rpx;
}

.invite-code-box {
  margin-top: 28rpx;
  min-height: 96rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1769ff;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
}

.invite-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.invite-action {
  height: 78rpx;
  font-size: 28rpx;
}

.invite-input-row {
  margin-top: 26rpx;
  min-height: 92rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
}

.invite-input {
  flex: 1;
  height: 76rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 650;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.bind-btn {
  margin-top: 22rpx;
}

.member-section {
  margin-top: 24rpx;
}

.member-head {
  padding: 26rpx 24rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-row {
  min-height: 112rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #edf1f7;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.member-avatar.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf4ff;
  color: #1769ff;
  font-weight: 700;
}

.member-main {
  flex: 1;
}

.member-name {
  margin-bottom: 8rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-line {
  padding: 42rpx 24rpx;
  text-align: center;
  color: #8b94a5;
}
