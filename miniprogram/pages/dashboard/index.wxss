.dashboard-page {
  padding-bottom: 42rpx;
}

.hero {
  margin-top: 26rpx;
  padding: 34rpx 28rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  background:
    radial-gradient(circle at 86% 10%, rgba(201, 164, 92, 0.34) 0, rgba(201, 164, 92, 0) 34%),
    linear-gradient(135deg, #102a43 0%, #174a63 44%, #0f766e 100%);
  box-shadow: 0 24rpx 56rpx rgba(16, 42, 67, 0.18);
}

.hero-left {
  min-width: 0;
}

.label-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  font-weight: 600;
}

.hero-amount {
  margin-top: 20rpx;
  font-size: 60rpx;
  line-height: 1;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 8rpx 22rpx rgba(2, 6, 23, 0.18);
  transform-origin: left center;
}

.hero-amount.amount-growing {
  animation: amount-pop 720ms ease-out;
}

.hero-delta {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
}

.hero-delta .red,
.hero-delta .green {
  font-weight: 850;
}

.hero-metrics {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.hero-metric {
  min-width: 0;
  min-height: 104rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f8fbff 0%, #f4f7fb 100%);
  border: 1rpx solid #e8edf5;
}

.metric-label {
  margin-bottom: 10rpx;
  color: #475467;
  font-size: 23rpx;
  font-weight: 600;
}

.metric-value {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.metric-value text {
  color: #0f172a;
  font-size: 36rpx;
}

.metric-value.debt {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.hero .help-icon {
  color: rgba(255, 255, 255, 0.82);
  border-color: rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.10);
}

.dark-mode .hero {
  border-color: rgba(255, 255, 255, 0.16);
  background:
    radial-gradient(circle at 86% 10%, rgba(201, 164, 92, 0.26) 0, rgba(201, 164, 92, 0) 34%),
    linear-gradient(135deg, #0b1f35 0%, #12384e 46%, #0d5f5a 100%);
  box-shadow: 0 24rpx 56rpx rgba(2, 6, 23, 0.34);
}

.dark-mode .hero-metric {
  background: #0b1220;
  border-color: #1f2937;
}

.dark-mode .hero .label-line,
.dark-mode .hero-delta {
  color: rgba(255, 255, 255, 0.72);
}

.dark-mode .hero-amount {
  color: #ffffff;
}

.legend-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex: 0 0 10rpx;
}

.composition {
  margin-top: 24rpx;
}

.composition-tabs {
  height: 58rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #f2f5fa;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.composition-tab {
  min-width: 82rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 24rpx;
  font-weight: 650;
}

.composition-tab.active {
  color: #174ea6;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(23, 78, 166, 0.10);
}

.asset-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.asset-row:last-child {
  border-bottom: 0;
}

.asset-main {
  flex: 1;
}

.asset-name {
  font-size: 30rpx;
  font-weight: 650;
  color: #111827;
}

.bar-track {
  margin-top: 18rpx;
  width: 100%;
  height: 10rpx;
  border-radius: 8rpx;
  background: #edf1f7;
  overflow: hidden;
}

.bar-fill {
  height: 10rpx;
  min-width: 8rpx;
  border-radius: 8rpx;
}

.asset-number {
  width: 178rpx;
  text-align: right;
}

.asset-amount {
  font-size: 29rpx;
  color: #111827;
  font-weight: 650;
}

.asset-meta {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  font-size: 22rpx;
}

.composition-chart {
  padding: 6rpx 0 2rpx;
}

.composition-chart-body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.composition-legend {
  flex: 1;
  min-width: 0;
}

.composition-legend-row {
  min-height: 50rpx;
  display: grid;
  grid-template-columns: 18rpx 1fr auto 62rpx;
  align-items: center;
  gap: 12rpx;
  font-size: 23rpx;
  border-bottom: 1rpx solid #f0f3f8;
}

.composition-legend-row:last-child {
  border-bottom: 0;
}

.composition-legend-name {
  color: #344054;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.composition-legend-value {
  color: #101827;
  font-weight: 700;
}

.completion-card {
  border-color: #ffd8a8;
  background: #fffaf3;
}

.completion-close {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b45309;
  background: rgba(245, 158, 11, 0.12);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 52rpx;
}

.completion-row {
  min-height: 96rpx;
  padding: 18rpx 0;
  display: grid;
  grid-template-columns: 14rpx 1fr auto;
  align-items: center;
  gap: 18rpx;
  color: #344054;
  font-size: 26rpx;
  border-top: 1rpx solid rgba(245, 158, 11, 0.18);
}

.completion-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.completion-main {
  min-width: 0;
}

.completion-category {
  color: #b45309;
  font-size: 23rpx;
  font-weight: 700;
}

.completion-title {
  margin-top: 8rpx;
  min-width: 0;
  color: #101827;
  font-size: 29rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.completion-more {
  margin-top: 12rpx;
  color: #b45309;
  font-size: 23rpx;
}

.guide-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1200;
  padding: 0 42rpx;
  background: rgba(15, 23, 42, 0.46);
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-panel {
  width: 100%;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 70rpx rgba(15, 23, 42, 0.22);
}

.guide-title {
  color: #101827;
  font-size: 36rpx;
  font-weight: 800;
}

.guide-desc {
  margin-top: 14rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.guide-steps {
  margin-top: 28rpx;
}

.guide-step {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.guide-step + .guide-step {
  margin-top: 16rpx;
}

.guide-step-index {
  width: 40rpx;
  height: 40rpx;
  flex: 0 0 40rpx;
  border-radius: 50%;
  background: #edf4ff;
  color: #1769ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 800;
}

.guide-step-text {
  color: #344054;
  font-size: 27rpx;
  font-weight: 600;
}

.guide-primary {
  margin-top: 34rpx;
}

.guide-secondary {
  margin-top: 8rpx;
}

@keyframes amount-pop {
  0% {
    opacity: 0.72;
    transform: translateY(8rpx) scale(0.98);
  }

  55% {
    opacity: 1;
    transform: translateY(0) scale(1.018);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
