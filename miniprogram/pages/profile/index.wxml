<view class="page profile-page {{themeClass}} {{viewing.isViewingFamily ? 'family-mode' : ''}}">
  <skeleton-screen wx:if="{{loading}}" type="profile"></skeleton-screen>

  <block wx:if="{{!loading}}">
    <view wx:if="{{viewing.isViewingFamily}}" class="family-view-banner">
      <text class="family-view-text">正在查看 {{viewing.viewingOwner.nickName}} 的资产数据</text>
      <button class="family-return-link" bindtap="returnMine">返回我的资产</button>
    </view>

    <view class="profile-head">
      <button wx:if="{{!profile.avatarUrl}}" class="avatar avatar-empty" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <text class="avatar-plus">+</text>
        <text class="avatar-tip">获取头像信息</text>
      </button>
      <button wx:else class="avatar avatar-image-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-image" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
      </button>

      <view class="profile-main">
        <view class="profile-name-row">
          <input
            class="profile-name-input"
            type="nickname"
            value="{{profile.nickName}}"
            placeholder="资产记录者"
            bindinput="onNicknameInput"
            bindblur="saveNickname"
          />
          <text class="profile-name-arrow">›</text>
        </view>
        <view class="muted">已完成 {{recordCount}} 次资产记录</view>
      </view>
    </view>

    <view class="privacy-card section">
      <icon-font name="eye-off" color="#1769FF"></icon-font>
      <view class="privacy-main">
        <view class="privacy-title">资产隐私</view>
        <view class="muted">开启后金额默认以 **** 展示</view>
      </view>
      <switch checked="{{profile.privacyEnabled}}" color="#1769FF" bindchange="onPrivacyChange" />
    </view>

    <view class="section setting-section">
      <view class="setting-row static">
        <view class="setting-left">
          <icon-font name="currency-cny" color="#1769FF" size="{{50}}" radius="{{15}}"></icon-font>
          <view>
            <view>资产单位</view>
            <view class="setting-desc">全部金额按人民币 CNY 统计</view>
          </view>
        </view>
        <view class="setting-value">元</view>
      </view>

      <view class="setting-row static">
        <view class="setting-left">
          <icon-font name="swap" color="#10B981" size="{{50}}" radius="{{15}}"></icon-font>
          <view>
            <view>对比口径</view>
            <view class="setting-desc">最新记录与选择的历史记录对比</view>
          </view>
        </view>
      </view>

      <view class="setting-row" bindtap="goReminder">
        <view class="setting-left">
          <icon-font name="bell" color="#0EA5E9" size="{{50}}" radius="{{15}}"></icon-font>
          <view>
            <view>记录提醒</view>
            <view class="setting-desc">{{reminderText}}</view>
          </view>
        </view>
        <view class="setting-value">
          <text class="chevron">›</text>
        </view>
      </view>

      <view class="setting-row" bindtap="goFamily">
        <view class="setting-left">
          <icon-font name="users" color="#7C3AED" size="{{50}}" radius="{{15}}"></icon-font>
          <view>
            <view>亲友资产</view>
            <view class="setting-desc">邀请亲友绑定，切换浏览资产数据</view>
          </view>
        </view>
        <view class="setting-value">
          <text class="chevron">›</text>
        </view>
      </view>
    </view>

    <view class="section section-pad insight-panel">
      <view class="insight-head">
        <view>
          <view class="section-title">{{monthlyReport.monthLabel}}资产月报</view>
          <view class="section-subtitle">{{monthlyReport.firstDate}} 至 {{monthlyReport.latestDate}} · {{monthlyReport.recordCountText}}</view>
        </view>
        <view class="insight-badge">月报</view>
      </view>
      <view class="insight-amount {{monthlyReport.netDeltaClass}}">{{monthlyReport.netDeltaText}}</view>
      <view class="insight-detail-grid">
        <view>
          <text>变化最大</text>
          <text>{{monthlyReport.bestCategoryName}}</text>
          <text class="{{monthlyReport.bestCategoryClass}}">{{monthlyReport.bestCategoryDeltaText}}</text>
        </view>
        <view>
          <text>负债变化</text>
          <text>信用卡欠款合计</text>
          <text class="{{monthlyReport.liabilityDeltaClass}}">{{monthlyReport.liabilityDeltaText}}</text>
        </view>
      </view>
    </view>

    <view class="section section-pad insight-panel health-panel">
      <view class="insight-head">
        <view>
          <view class="section-title">资产健康分</view>
          <view class="section-subtitle">基于负债、现金类资产、记录频率和目标进度</view>
        </view>
        <view class="health-score-large">{{health.score}}</view>
      </view>
      <view class="health-status-row">
        <view>
          <view class="health-level-large">{{health.level}}</view>
          <view class="health-summary">{{health.primaryTip}}</view>
        </view>
      </view>
      <view class="health-detail-grid">
        <view>
          <text>负债率</text>
          <text>{{health.liabilityRateText}}</text>
        </view>
        <view>
          <text>现金占比</text>
          <text>{{health.cashRatioText}}</text>
        </view>
        <view>
          <text>目标进度</text>
          <text>{{health.goalProgressText}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
