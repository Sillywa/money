.profile-page {
  padding-bottom: 44rpx;
}

.profile-head {
  margin-top: 20rpx;
  padding: 24rpx 4rpx 34rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 126rpx;
  height: 126rpx;
  flex: 0 0 126rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #edf4ff;
  color: #1769ff;
}

.avatar-plus {
  font-size: 44rpx;
  font-weight: 800;
}

.avatar-tip {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 1.2;
}

.avatar-image-btn {
  background: transparent;
}

.avatar-image {
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.profile-name-input {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 420rpx;
  height: 56rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #111827;
}

.profile-name-arrow {
  flex: 0 0 auto;
  color: #9aa3b2;
  font-size: 40rpx;
  line-height: 1;
}

.return-mine {
  height: 76rpx;
  margin-bottom: 22rpx;
  border-radius: 16rpx;
  background: #174ea6;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.privacy-card {
  height: 118rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.privacy-main {
  flex: 1;
}

.privacy-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.setting-section {
  margin-top: 28rpx;
  padding: 8rpx 24rpx;
}

.setting-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf1f7;
}

.setting-row:last-child {
  border-bottom: 0;
}

.setting-row.static {
  color: #111827;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.setting-desc {
  margin-top: 8rpx;
  color: #7a8494;
  font-size: 23rpx;
  font-weight: 400;
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #7a8494;
  font-size: 26rpx;
}

.insight-panel {
  margin-top: 24rpx;
}

.insight-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.insight-badge {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  color: #1769ff;
  background: #edf4ff;
  font-size: 23rpx;
  font-weight: 750;
}

.insight-amount {
  margin-top: 24rpx;
  font-size: 52rpx;
  line-height: 1.1;
  font-weight: 850;
}

.insight-detail-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.insight-detail-grid view,
.health-detail-grid view {
  min-width: 0;
  min-height: 112rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.insight-detail-grid text:first-child,
.health-detail-grid text:first-child {
  color: #667085;
  font-size: 23rpx;
}

.insight-detail-grid text:nth-child(2) {
  color: #101827;
  font-size: 28rpx;
  font-weight: 750;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.insight-detail-grid text:last-child,
.health-detail-grid text:last-child {
  font-size: 30rpx;
  font-weight: 850;
}

.health-score-large {
  width: 92rpx;
  height: 92rpx;
  flex: 0 0 92rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #1769ff, #10b981);
  font-size: 40rpx;
  font-weight: 850;
}

.health-status-row {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.health-level-large {
  color: #101827;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 850;
}

.health-summary {
  margin-top: 10rpx;
  color: #475467;
  font-size: 25rpx;
  line-height: 1.45;
}

.health-detail-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.health-detail-grid text:last-child {
  color: #101827;
}
