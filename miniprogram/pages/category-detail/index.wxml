<view class="page detail-page {{themeClass}} {{viewing.isViewingFamily ? 'family-mode' : ''}}">
  <skeleton-screen wx:if="{{loading}}" type="detail"></skeleton-screen>

  <block wx:if="{{!loading && category}}">
    <view wx:if="{{viewing.isViewingFamily}}" class="family-view-banner">
      <text class="family-view-text">正在查看 {{viewing.viewingOwner.nickName}} 的资产数据</text>
      <button class="family-return-link" bindtap="returnMine">返回我的资产</button>
    </view>

    <record-strip
      latest-date="{{bundle.current.recordDate}}"
      compare-date="{{compareDate}}"
      compare-options="{{compareOptions}}"
      compare-index="{{compareIndex}}"
      family-mode="{{viewing.isViewingFamily}}"
      bind:change="onCompareChange"
    ></record-strip>

    <view class="detail-hero">
    <view class="hero-main">
      <view class="hero-label">{{category.amountLabel}}（元）</view>
      <view class="hero-value {{category.liability ? 'red' : ''}}">
        <block wx:if="{{privacyMode}}">{{summary.amountDisplay}}</block>
        <block wx:else>{{category.liability ? '-' : ''}}{{summary.amountDisplay}}</block>
      </view>
      <view class="hero-change">
        <text>较对比</text>
        <text class="{{summary.deltaClass}}">{{summary.deltaText}}</text>
      </view>
    </view>
    <view class="hero-side">
      <view class="side-cell">
        <view class="side-value">{{summary.count}}</view>
        <view class="muted">{{category.countLabel}}</view>
      </view>
      <view class="side-cell">
        <view class="side-value">{{summary.percentText}}</view>
        <view class="muted label-with-help">
          <text>{{category.liability ? '负债率' : '占净资产'}}</text>
          <text wx:if="{{category.liability}}" class="help-icon" catchtap="showMetricHelp" data-type="liabilityRate">?</text>
        </view>
      </view>
    </view>
    </view>

    <view class="section section-pad">
    <view class="section-head">
      <view>
        <view class="section-title">{{category.trendTitle}}</view>
        <view class="section-subtitle">按录入日期统计</view>
      </view>
    </view>
    <line-chart points="{{trendPoints}}" color="{{category.accent}}" privacy-mode="{{privacyMode}}" dark-mode="{{themeClass === 'dark-mode'}}"></line-chart>
    </view>

    <view class="action-row section">
    <view class="action-cell" bindtap="addItem">
      <text class="action-icon">＋</text>
      <text>{{category.addText}}</text>
    </view>
    </view>

    <view class="section list-section">
    <view class="list-head">
      <view>
        <view class="section-title">{{category.listTitle}}</view>
      </view>
      <view class="muted">按日期分组</view>
    </view>

    <block wx:for="{{historyGroups}}" wx:key="recordDate" wx:for-item="group">
      <view class="history-date-head" bindtap="toggleHistoryGroup" data-record-date="{{group.recordDate}}">
        <view>
          <view class="history-date">{{group.recordDate}}</view>
          <view class="muted">{{group.rows.length}} 条资产记录</view>
        </view>
        <view class="history-total">
          <view>{{group.totalText}}</view>
          <view class="history-subline">
            <text class="{{group.deltaClass}}">{{group.deltaText}}</text>
            <text class="history-toggle">{{group.expanded ? '收起' : '展开'}}</text>
            <text class="history-arrow {{group.expanded ? 'expanded' : ''}}"></text>
          </view>
        </view>
      </view>

      <view wx:if="{{group.expanded}}">
        <block wx:for="{{group.rows}}" wx:key="swipeKey">
          <view
            class="item-swipe"
            data-key="{{item.swipeKey}}"
            bindtouchstart="onItemTouchStart"
            bindtouchend="onItemTouchEnd"
          >
            <view
              class="item-delete"
              catchtap="confirmDeleteItem"
              data-key="{{item.swipeKey}}"
              data-index="{{item.index}}"
              data-item-id="{{item.id}}"
              data-record-date="{{group.recordDate}}"
              data-title="{{item.title}}"
            >{{deletingKey === item.swipeKey ? '删除中' : '删除'}}</view>
            <view
              class="item-row {{item.swiped ? 'swiped' : ''}}"
              bindtap="editItem"
              data-index="{{item.index}}"
              data-record-date="{{group.recordDate}}"
            >
              <icon-font name="{{category.icon}}" color="{{category.color}}"></icon-font>
              <view class="item-main">
                <view class="item-title">{{item.title}}</view>
                <view class="item-sub" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
                <view class="field-line" wx:if="{{item.editorName}}">
                  <text>编辑人 {{item.editorName}}</text>
                </view>
                <view class="field-line" wx:if="{{isCreditCard && (item.billDay || item.repaymentDay)}}">
                  <text wx:if="{{item.billDay}}">账单日 {{item.billDay}}</text>
                  <text wx:if="{{item.repaymentDay}}">还款日 {{item.repaymentDay}}</text>
                </view>
              </view>
              <view class="item-amount">
                <view>{{item.amountText}}</view>
                <view class="{{item.deltaClass}}">{{item.deltaText}}</view>
              </view>
              <view class="chevron">›</view>
            </view>
          </view>
        </block>
      </view>
    </block>

    <view wx:if="{{hasMoreHistory}}" class="history-more">继续下滑加载更多记录</view>
    <view wx:else class="history-more muted">已展示全部记录</view>
    </view>
  </block>
</view>
