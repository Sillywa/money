<view class="page reminder-page {{themeClass}} {{viewing.isViewingFamily ? 'family-mode' : ''}}">
  <view wx:if="{{viewing.isViewingFamily}}" class="family-view-banner">
    <text class="family-view-text">正在查看 {{viewing.viewingOwner.nickName}} 的资产数据</text>
    <button class="family-return-link" bindtap="returnMine">返回我的资产</button>
  </view>

  <view class="section section-pad">
    <view class="section-title title-with-icon">
      <icon-font name="bell" color="#0EA5E9" size="{{44}}" radius="{{14}}"></icon-font>
      <text>每月提醒</text>
    </view>
    <view class="section-subtitle">提醒时间固定为所选日期早上 10:00</view>

    <picker mode="selector" range="{{days}}" value="{{dayIndex}}" bindchange="onDayChange">
      <view class="picker-row">
        <icon-font name="calendar" color="#1769FF" size="{{50}}" radius="{{15}}"></icon-font>
        <view class="picker-main">
          <view class="picker-title">提醒日期</view>
          <view class="muted">每月 {{dayIndex + 1}} 日 10:00</view>
        </view>
        <view class="picker-value">{{days[dayIndex]}} ›</view>
      </view>
    </picker>
  </view>

  <button class="btn-primary save-btn" loading="{{saving}}" bindtap="save">保存提醒</button>
</view>
