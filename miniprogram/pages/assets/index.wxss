.assets-page {
  padding-bottom: 44rpx;
}

.date-card {
  position: sticky;
  top: 0;
  z-index: 20;
  margin-top: 24rpx;
  padding: 0 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.date-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.date-title {
  margin-bottom: 8rpx;
  color: #344054;
  font-size: 29rpx;
  font-weight: 650;
}

.date-value {
  max-width: 360rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  color: #1769ff;
  font-size: 27rpx;
  font-weight: 650;
  text-align: right;
}

.date-arrow {
  color: #9aa3b2;
  font-size: 34rpx;
  line-height: 1;
}

.summary-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 26rpx 28rpx;
}

.summary-item {
  min-width: 0;
}

.kpi-value {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #111827;
}

.kpi-value.small {
  font-size: 30rpx;
}

.kpi-value.green {
  color: #10a976;
}

.kpi-value.red {
  color: #e84b52;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  margin: 22rpx 0;
}

.filters {
  display: flex;
  gap: 18rpx;
}

.group {
  margin-top: 18rpx;
}

.group-head {
  min-height: 112rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  background: #eef5ff;
  border-bottom: 1rpx solid #d8e7ff;
}

.head-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.group-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #111827;
}

.head-right {
  width: 210rpx;
  text-align: right;
  font-size: 31rpx;
  font-weight: 700;
  color: #111827;
}

.group-chevron {
  margin-left: 14rpx;
  color: #8b94a5;
  font-size: 42rpx;
  line-height: 1;
}

.detail-row {
  min-height: 116rpx;
  padding: 20rpx 52rpx 20rpx 24rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #edf1f7;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.detail-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sub {
  margin-top: 8rpx;
  color: #7a8494;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-right {
  width: 210rpx;
  text-align: right;
  font-size: 30rpx;
  font-weight: 650;
  color: #111827;
}

.complete-line {
  margin: 26rpx 0;
  text-align: center;
  color: #8b94a5;
  font-size: 24rpx;
}
