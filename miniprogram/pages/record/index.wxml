<view class="page record-page {{themeClass}}">
  <skeleton-screen wx:if="{{loading}}" type="record"></skeleton-screen>

  <block wx:if="{{!loading && category}}">
    <view wx:if="{{viewing.isViewingFamily}}" class="family-view-banner">正在查看 {{viewing.viewingOwner.nickName}} 的资产数据</view>

    <view class="form-title">
    <view class="form-accent"></view>
    <view>
      <view class="section-title">{{category.name}}信息</view>
      <view class="section-subtitle">{{recordHint}}</view>
    </view>
    </view>

    <view class="section date-picker-section">
      <picker mode="date" value="{{recordDate}}" bindchange="onRecordDateChange">
        <view class="date-picker-row">
          <view>
            <view class="date-picker-title">记录日期</view>
            <view class="muted">选择这笔资产归属的日期</view>
          </view>
          <view class="date-picker-value">
            <text>{{recordDate}}</text>
            <text class="date-picker-arrow">›</text>
          </view>
        </view>
      </picker>
    </view>

    <view wx:if="{{showAccountPicker}}" class="section account-picker-section">
      <picker mode="selector" range="{{accountPickerOptions}}" value="{{accountPickerIndex}}" bindchange="onAccountChange">
        <view class="account-picker-row">
          <view>
            <view class="account-picker-title">账户名称</view>
            <view class="muted">选择历史账户后自动填充基础信息</view>
          </view>
          <view class="account-picker-value">
            <text>{{selectedAccountLabel}}</text>
            <text class="account-picker-arrow">›</text>
          </view>
        </view>
      </picker>
    </view>

    <view class="section form-section">
    <block wx:for="{{fields}}" wx:key="key">
      <view class="form-row {{item.rowClass}}">
        <view class="form-label">
          <text>{{item.label}}</text>
          <text class="required" wx:if="{{item.required}}">*</text>
        </view>
        <input
          wx:if="{{!item.isTextarea}}"
          class="form-input"
          value="{{item.value}}"
          placeholder="{{item.placeholder}}"
          type="{{item.inputType}}"
          data-field="{{item.key}}"
          data-index="{{index}}"
          bindinput="onInput"
        />
        <textarea
          wx:else
          class="form-textarea"
          value="{{item.value}}"
          placeholder="{{item.placeholder}}"
          maxlength="80"
          data-field="{{item.key}}"
          data-index="{{index}}"
          bindinput="onInput"
        />
      </view>
    </block>
    </view>

    <view class="section preview-card">
    <icon-font name="{{category.icon}}" color="{{category.color}}"></icon-font>
    <view class="preview-main">
      <view class="preview-title">保存后计入{{category.name}}{{category.liability ? '负债' : '资产'}}</view>
      <view class="muted">记录日期 {{recordDate}} · 人民币</view>
    </view>
    <view class="preview-amount {{category.liability ? 'red' : 'blue'}}">
      {{category.liability ? '-' : ''}}{{amountPreview}}
    </view>
    </view>

    <view class="bottom-actions">
    <button class="btn-secondary" bindtap="goBack">取消</button>
    <button class="btn-primary" loading="{{saving}}" disabled="{{saving}}" bindtap="save">
      <icon-font wx:if="{{!saving}}" name="check" color="transparent" size="{{30}}" radius="{{0}}" plain="{{true}}"></icon-font>
      <text>{{saving ? '保存中' : '保存'}}</text>
    </button>
    </view>
  </block>
</view>
