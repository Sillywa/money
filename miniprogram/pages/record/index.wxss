.record-page {
  padding-bottom: 150rpx;
}

.form-title {
  margin-top: 18rpx;
  padding: 20rpx 0 8rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.form-accent {
  width: 8rpx;
  height: 44rpx;
  border-radius: 6rpx;
  background: #1769ff;
}

.form-section {
  padding: 0 24rpx;
}

.account-picker-section {
  padding: 0 24rpx;
}

.date-picker-section {
  padding: 0 24rpx;
}

.account-picker-row,
.date-picker-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.account-picker-title,
.date-picker-title {
  margin-bottom: 8rpx;
  color: #344054;
  font-size: 29rpx;
  font-weight: 650;
}

.account-picker-value,
.date-picker-value {
  max-width: 360rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  color: #1769ff;
  font-size: 27rpx;
  font-weight: 650;
  text-align: right;
}

.account-picker-value text:first-child {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.account-picker-arrow {
  color: #9aa3b2;
  font-size: 34rpx;
  line-height: 1;
}

.date-picker-arrow {
  color: #9aa3b2;
  font-size: 34rpx;
  line-height: 1;
}

.form-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #edf1f7;
}

.form-row:last-child {
  border-bottom: 0;
}

.textarea-row {
  align-items: flex-start;
  padding: 28rpx 0;
}

.form-label {
  width: 216rpx;
  color: #344054;
  font-size: 29rpx;
}

.required {
  margin-left: 6rpx;
  color: #e84b52;
}

.form-input {
  flex: 1;
  height: 80rpx;
  text-align: right;
  font-size: 30rpx;
  color: #111827;
}

.form-textarea {
  flex: 1;
  min-height: 150rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  font-size: 27rpx;
  color: #111827;
}

.preview-card {
  margin-top: 28rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.preview-main {
  flex: 1;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 650;
  color: #344054;
}

.preview-amount {
  font-size: 34rpx;
  font-weight: 800;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 132rpx;
  padding: 18rpx 28rpx 28rpx;
  display: grid;
  grid-template-columns: 0.82fr 1.45fr;
  gap: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #e7ecf4;
}
